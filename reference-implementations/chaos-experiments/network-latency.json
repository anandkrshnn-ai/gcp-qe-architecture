{
    "title": "Inject Network Latency between GKE Services",
    "description": "Verify that the frontend service handles 500ms latency to the backend service gracefully.",
    "tags": ["gke", "latency", "resilience"],
    "steady-state-hypothesis": {
        "title": "Services are healthy",
        "probes": [
            {
                "type": "probe",
                "name": "frontend-must-respond-under-200ms",
                "tolerance": 200,
                "provider": {
                    "type": "python",
                    "module": "chaosaddons.gcp.probes",
                    "func": "http_response_time",
                    "arguments": {
                        "url": "${frontend_url}"
                    }
                }
            }
        ]
    },
    "method": [
        {
            "type": "action",
            "name": "inject-latency",
            "provider": {
                "type": "python",
                "module": "chaosaddons.gcp.actions",
                "func": "inject_network_latency",
                "arguments": {
                    "project_id": "${gcp_project}",
                    "region": "${gcp_region}",
                    "target_service": "backend-api",
                    "latency_ms": 500
                }
            },
            "pauses": {
                "after": 30
            }
        }
    ],
    "rollbacks": [
        {
            "type": "action",
            "name": "remove-latency",
            "provider": {
                "type": "python",
                "module": "chaosaddons.gcp.actions",
                "func": "remove_network_latency"
            }
        }
    ]
}
